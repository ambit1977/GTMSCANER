{
  "manifest_version": 3,
  "name": "GTM Scanner",
  "version": "1.0.0",
  "description": "現在のウェブサイトに読み込まれているGTMコンテナを解析し、タグ・トリガー・変数の概要をレポートします",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://www.googletagmanager.com/*",
    "http://www.googletagmanager.com/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    },
    "default_title": "GTM Scanner"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png"
  }
}
